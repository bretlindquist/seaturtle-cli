#!/usr/bin/env zsh
set -euo pipefail

repo_root="${0:A:h:h}"
cli_path="$repo_root/dist/cli.js"
package_json_path="$repo_root/source/package.json"

if [[ ! -f "$cli_path" ]]; then
  echo "ct is not built yet." >&2
  echo "Build once with: node scripts/build-cli.mjs --no-minify" >&2
  echo "Or install wrappers with: ./scripts/install-local-cli.sh --build" >&2
  exit 1
fi

extract_repo_version() {
  node -e 'const fs=require("fs"); const pkg=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(pkg.version || "");' "$package_json_path" 2>/dev/null || true
}

extract_built_version() {
  sed -n 's#^// Version: ##p' "$cli_path" | head -n 1
}

is_interactive_launch() {
  [[ $# -eq 0 && -t 0 && -t 1 ]]
}

get_update_command_display() {
  print -r -- "node ${cli_path:q} update"
}

handle_stale_build() {
  local stale_message
  stale_message="Local CT version is outdated: installed $built_version, current $repo_version."
  local update_command
  update_command="$(get_update_command_display)"

  echo "$stale_message" >&2
  echo "Update with: $update_command" >&2

  if [[ "${CT_LOCAL_WRAPPER_ASSUME_INTERACTIVE:-0}" == "1" ]]; then
    :
  elif ! is_interactive_launch "$@"; then
    return 0
  fi

  echo >&2
  echo "Choose: [u] update now, [c] continue with current installed version, [q] quit" >&2

  local action="${CT_LOCAL_WRAPPER_STALE_ACTION:-}"
  if [[ -z "$action" ]]; then
    printf "> " >&2
    read -r action
  fi

  case "${action:l}" in
    u|update|b|build|rebuild)
      if ! node "$cli_path" update; then
        exit 1
      fi
      exec node "$cli_path" "$@"
      ;;
    c|continue)
      return 0
      ;;
    q|quit|exit)
      exit 1
      ;;
    *)
      echo "Unknown choice: ${action}. Aborting." >&2
      exit 1
      ;;
  esac
}

repo_version="$(extract_repo_version)"
built_version="$(extract_built_version)"

if [[ -n "${CT_LOCAL_WRAPPER_REPO_VERSION_OVERRIDE:-}" ]]; then
  repo_version="${CT_LOCAL_WRAPPER_REPO_VERSION_OVERRIDE}"
fi

if [[ -n "${CT_LOCAL_WRAPPER_BUILT_VERSION_OVERRIDE:-}" ]]; then
  built_version="${CT_LOCAL_WRAPPER_BUILT_VERSION_OVERRIDE}"
fi

if [[ -n "$repo_version" && -n "$built_version" && "$repo_version" != "$built_version" ]]; then
  handle_stale_build "$@"
fi

export CLAUDE_CODE_USE_OPENAI_CODEX=1
exec node "$cli_path" "$@"
